@page "/projects"
@inject HttpClient Http

<PageTitle>Projects</PageTitle>

<h1>Projects</h1>

@if (projects == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Date</th>
                <th aria-label="Name">Name</th>
                <th aria-label="Summary">Summary</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var project in projects)
            {
                <tr>
                    <td>@project.Date.ToShortDateString()</td>
                    <td>@project.Name</td>
                    <td>@project.Summary</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private ProjectDescription[]? projects;

    protected override async Task OnInitializedAsync()
    {
        projects = await Http.GetFromJsonAsync<ProjectDescription[]>("sample-data/project.json");
    }

    public class ProjectDescription
    {
        public DateOnly Date { get; set; }

        public string? Name { get; set; }

        public string? Summary { get; set; }

    }
}
